@model PruebaDsesempeño.Models.SpaceViewModel

@{
    ViewData["Title"] = "Spaces";
}

<div class="max-w-7xl mx-auto space-y-8">
    
    <div class="flex justify-between items-center">
        <div>
            <h1 class="text-3xl font-bold">Space Management</h1>
            <p class="text-gray-500">Overview of spaces</p>
        </div>
    </div>
    
    <div class="bg-white p-6 rounded-xl shadow space-y-4">
        
        @if (TempData["Success"] != null)
        {
            <div class="bg-teal-100 border-t-4 border-teal-500 rounded-b text-teal-900 px-4 py-3 shadow-md" role="alert">
                <div class="flex">
                    <div class="py-1"><svg class="fill-current h-6 w-6 text-teal-500 mr-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M2.93 17.07A10 10 0 1 1 17.07 2.93 10 10 0 0 1 2.93 17.07zm12.73-1.41A8 8 0 1 0 4.34 4.34a8 8 0 0 0 11.32 11.32zM9 11V9h2v6H9v-4zm0-6h2v2H9V5z"/></svg></div>
                    <div>
                        <p class="font-bold">@TempData["Message"]</p>
                    </div>
                </div>
            </div>
        }

        <h2 class="text-lg font-semibold text-gray-700">Space Register</h2>

        <form asp-controller="Space" asp-action="Store" method="post"
              class="grid md:grid-cols-4 gap-4 items-end">

            <div>
                <label class="text-sm text-gray-500">Name</label>
                <input type="text" name="Name"
                       class="w-full mt-1 p-2 border rounded-lg focus:ring-2 focus:ring-green-500 outline-none"
                       placeholder="Amazing Space" />
            </div>

            <div>
                <label class="text-sm text-gray-500">Type</label>
                <select name="Type"
                        class="w-full mt-1 p-2 border rounded-lg bg-white focus:ring-2 focus:ring-green-500 outline-none">
                    <option value="" disabled selected>Select an option</option>
                    <option value="1">Soccer</option>
                    <option value="2">Football</option>
                    <option value="3">Basketball</option>
                    <option value="4">Tennis</option>
                    <option value="5">Squash</option>
                    <option value="6">Archery</option>
                    <option value="7">Volley</option>
                </select>
            </div>

            <div>
                <label class="text-sm text-gray-500">Capacity</label>
                <input type="number" name="Capacity"
                       class="w-full mt-1 p-2 border rounded-lg focus:ring-2 focus:ring-green-500 outline-none"
                       placeholder="1 - 20"
                       min="1"
                       max="20" />
            </div>

            <div class="md:col-span-4 flex justify-end mt-2">
                <button type="submit"
                        class="bg-green-500 hover:bg-green-600 text-white px-6 py-2 rounded-lg transition">
                    Create Space
                </button>
            </div>

        </form>
    </div>
    
    <div class="bg-white rounded shadow overflow-hidden">

        <table class="w-full">
            <thead class="bg-gray-100 text-left">
                <tr>
                    <th class="p-4">Name</th>
                    <th class="p-4">Type</th>
                    <th class="p-4">Capacity</th>
                    <th class="p-4">Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.SpaceList != null && Model.SpaceList.Any())
                {
                    @foreach (var space in Model.SpaceList)
                    {
                        <tr class="border-t">
                            <td class="p-4">@space.Name</td>
                            <td class="p-4">@space.Type</td>
                            <td class="p-4">@space.Capacity</td>
                            <td class="p-4">
                                <div class="flex items-center gap-2">

                                    <a asp-controller="User"
                                       asp-action="Edit"
                                       asp-route-id="@space.Id"
                                       class="bg-green-500 hover:bg-green-600 text-white text-sm font-medium px-4 py-2 rounded-lg transition">
                                        Edit
                                    </a>

                                    <form asp-controller="User"
                                          asp-action="DeleteUser"
                                          asp-route-id="@space.Id">
                                        <button type="submit"
                                                class="bg-red-500 hover:bg-red-600 text-white text-sm font-medium px-4 py-2 rounded-lg transition">
                                            Remove
                                        </button>
                                    </form>

                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr class="border-t">
                        <td>No spaces registered yet.</td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

</div>